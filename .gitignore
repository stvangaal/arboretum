__pycache__/
*.pyc
*.pyo
.DS_Store
*.egg-info/
dist/
/build/
.venv/
venv/
.env
*.db-journal
.superpowers/

# Session-handoff cache (issue #155). Refreshed on session start by
# .claude/hooks/session-start.sh and by the /handoff skill. Safe to
# delete — will be regenerated from GitHub on the next refresh.
.arboretum/next-cache.json
.arboretum/next-cache.json.tmp
.arboretum/next-cache.err
.arboretum/roadmap-pulse.json
.arboretum/roadmap-pulse.json.tmp
.arboretum/update-cache.json
.arboretum/update-cache.json.tmp

# Session-handoff transient markers (issue #251).
.arboretum/handoff-done
.arboretum/handoff-nudged
.arboretum/handoff-pending.json

# Agent-target task briefs (WS2 of #295). Session artifacts written by
# /start when an issue is triaged as agent-target. Not source.
.arboretum/agent-briefs/

# Additional runtime caches under .arboretum/ — same posture as the
# already-ignored next-cache/handoff-* files: regenerated by scripts/skills,
# safe to delete, not source-of-truth.
.arboretum/active-stage-cache.json
.arboretum/log-comments-cache.json

# Runtime lock files and worktree storage under .claude/. Lock files are
# session-scoped; worktrees are git-managed alternate working trees that
# should never be tracked as ordinary files.
.claude/scheduled_tasks.lock
.claude/worktrees/

# Sibling agent-tool working directories. AGENTS.md is the vendor-neutral
# guidance file checked in; the per-tool .agents/ / .claire/ / .codex/
# directories carry local hooks, skills, and worktree caches that aren't
# part of the arboretum framework distribution.
.agents/
.claire/
.codex/
